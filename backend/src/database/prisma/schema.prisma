generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id       String @id @default(uuid())
  roleName String @unique @map("role_name")
  users    User[]

  @@map("roles")
}

model User {
  id             String    @id @default(uuid())
  employeeId     String?   @map("employee_id")
  roleId         String    @map("role_id")
  email          String    @unique
  passwordHash   String    @map("password_hash")
  walletAddress  String?   @map("wallet_address")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  employee       Employee? @relation(fields: [employeeId], references: [id])
  role           Role      @relation(fields: [roleId], references: [id])
  auditLogs      AuditLog[]

  @@map("users")
}

model Employee {
  id               String       @id @default(uuid())
  employeeCode     String       @unique @map("employee_code")
  fullName         String       @map("full_name")
  phoneEncrypted   String       @map("phone_encrypted")
  addressEncrypted String       @map("address_encrypted")
  departmentId     String       @map("department_id")
  positionId       String       @map("position_id")
  hireDate         DateTime     @map("hire_date")
  status           Boolean      @default(true)
  department       Department   @relation(fields: [departmentId], references: [id])
  position         Position     @relation(fields: [positionId], references: [id])
  users            User[]
  evaluations      Evaluation[]
  promotions       PromotionHistory[]

  @@map("employees")
}

model Department {
  id             String     @id @default(uuid())
  departmentName String     @unique @map("department_name")
  employees      Employee[]

  @@map("departments")
}

model Position {
  id             String    @id @default(uuid())
  positionName   String    @map("position_name")
  level          Int
  employees      Employee[]
  oldPromotions  PromotionHistory[] @relation("OldPosition")
  newPromotions  PromotionHistory[] @relation("NewPosition")

  @@map("positions")
}

model EvaluationPeriod {
  id         String       @id @default(uuid())
  periodName String       @map("period_name")
  startDate  DateTime     @map("start_date")
  endDate    DateTime     @map("end_date")
  status     String
  evaluations Evaluation[]

  @@map("evaluation_periods")
}

model Evaluation {
  id               String       @id @default(uuid())
  employeeId       String       @map("employee_id")
  managerId        String       @map("manager_id")
  periodId         String       @map("period_id")
  totalScore       Decimal      @map("total_score")
  encryptedComment String       @map("encrypted_comment")
  documentPath     String?      @map("document_path")
  documentHash     String       @map("document_hash")
  blockchainStatus String       @map("blockchain_status")
  status           String
  createdAt        DateTime     @default(now()) @map("created_at")
  employee         Employee     @relation(fields: [employeeId], references: [id])
  period           EvaluationPeriod @relation(fields: [periodId], references: [id])
  details          EvaluationDetail[]
  promotionRequests PromotionRequest[]
  blockchainTransactions BlockchainTransaction[]

  @@map("evaluations")
}

model EvaluationDetail {
  id           String     @id @default(uuid())
  evaluationId String     @map("evaluation_id")
  indicator    String
  score        Int
  weight       Decimal
  notes        String?
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id])

  @@map("evaluation_details")
}

model PromotionRequest {
  id                String     @id @default(uuid())
  evaluationId      String     @map("evaluation_id")
  requestedPosition String     @map("requested_position")
  requestedBy       String     @map("requested_by")
  status            String
  createdAt         DateTime   @default(now()) @map("created_at")
  evaluation        Evaluation @relation(fields: [evaluationId], references: [id])

  @@map("promotion_requests")
}

model PromotionHistory {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  oldPosition String   @map("old_position")
  newPosition String   @map("new_position")
  approvedBy  String   @map("approved_by")
  promotedAt  DateTime @default(now()) @map("promoted_at")
  employee    Employee @relation(fields: [employeeId], references: [id])
  oldPositionRef Position @relation("OldPosition", fields: [oldPosition], references: [id])
  newPositionRef Position @relation("NewPosition", fields: [newPosition], references: [id])

  @@map("promotion_history")
}

model BlockchainTransaction {
  id              String     @id @default(uuid())
  evaluationId    String     @map("evaluation_id")
  contractAddress String     @map("contract_address")
  transactionHash String     @unique @map("transaction_hash")
  blockNumber     BigInt?    @map("block_number")
  walletAddress   String     @map("wallet_address")
  network         String
  syncStatus      String     @map("sync_status")
  createdAt       DateTime   @default(now()) @map("created_at")
  evaluation      Evaluation @relation(fields: [evaluationId], references: [id])

  @@map("blockchain_transactions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  activity  String
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

