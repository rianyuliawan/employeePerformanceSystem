PORT=5000
DATABASE_URL=postgresql://eps:eps_password@localhost:5432/employee_performance?schema=public
JWT_SECRET=change-this-development-secret
AES_SECRET_KEY=change-this-32-byte-minimum-secret
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
SMART_CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
NODE_ENV=development

# Supabase Storage — required for uploaded/generated files (e.g. promotion SK
# PDFs) to persist on serverless deployments (Vercel etc). Falls back to local
# disk in ./uploads when left empty (fine for local dev only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=docs

